# CODEOWNERS
# 
# Hangi dosya değişirse kim review etmeli?
# Bu dosya sayesinde PR açıldığında otomatik reviewer atanır.
# Yoksa "kimin işi bu?" sorusuyla 3 gün geçer.
#
# Syntax: pattern  @kullanıcı-adı veya @organizasyon/takım

# Güvenlik kritik alanlar — çok dikkatli olunmalı
/internal/auth/           @ahmetvural79/security-team
/SECURITY.md              @ahmetvural79/security-team
/.github/workflows/       @ahmetvural79/security-team

# Core tunnel logic
/internal/tunnel/         @ahmetvural79/core-team
/internal/proxy/          @ahmetvural79/core-team

# Config yönetimi — breaking change riski yüksek
/internal/config/         @ahmetvural79/core-team

# CLI komutları
/cmd/                     @ahmetvural79/core-team

# CI/CD değişiklikleri de önemli
/.goreleaser.yaml         @ahmetvural79/core-team
/.github/                 @ahmetvural79/core-team

# Doküman — daha hafif ama review yine de iyidir
/README.md                @ahmetvural79/docs-team
/landing/                 @ahmetvural79/design-team

# go.mod / go.sum — dependency değişikliği
# (bilen biri baksın lütfen)
/go.mod                   @ahmetvural79/security-team
/go.sum                   @ahmetvural79/security-team
