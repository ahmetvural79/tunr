{
  "name": "vscode-tunr",
  "displayName": "tunr — Local → Public Tunnel",
  "description": "Open, stop, and monitor tunnels directly from VS Code. Say goodbye to ngrok.",
  "version": "0.1.0",
  "publisher": "ahmetvural79",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmetvural79/tunr"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Debuggers"],
  "keywords": ["tunnel", "localhost", "public url", "ngrok alternative", "tunr"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tunr.share",
        "title": "tunr: Share Current Port",
        "icon": "$(broadcast)"
      },
      {
        "command": "tunr.stop",
        "title": "tunr: Stop Tunnel",
        "icon": "$(debug-stop)"
      },
      {
        "command": "tunr.status",
        "title": "tunr: Show Tunnel Status",
        "icon": "$(pulse)"
      },
      {
        "command": "tunr.openDashboard",
        "title": "tunr: Open HTTP Inspector",
        "icon": "$(preview)"
      },
      {
        "command": "tunr.copyURL",
        "title": "tunr: Copy Tunnel URL",
        "icon": "$(copy)"
      }
    ],
    "configuration": {
      "title": "tunr",
      "properties": {
        "tunr.defaultPort": {
          "type": "number",
          "default": 3000,
          "description": "Default port used when opening a tunnel"
        },
        "tunr.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start a tunnel when VS Code opens"
        },
        "tunr.binaryPath": {
          "type": "string",
          "default": "tunr",
          "description": "Absolute path to the tunr binary (set this if not in PATH)"
        },
        "tunr.dashboardPort": {
          "type": "number",
          "default": 19842,
          "description": "Dashboard/inspector port"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tunr-sidebar",
          "title": "tunr",
          "icon": "$(broadcast)"
        }
      ]
    },
    "views": {
      "tunr-sidebar": [
        {
          "id": "tunr.tunnelView",
          "name": "Active Tunnels",
          "when": "true"
        },
        {
          "id": "tunr.requestView",
          "name": "Recent Requests",
          "when": "true"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {"command": "tunr.share"},
        {"command": "tunr.stop"},
        {"command": "tunr.status"},
        {"command": "tunr.openDashboard"},
        {"command": "tunr.copyURL"}
      ],
      "editor/context": [
        {
          "command": "tunr.share",
          "group": "tunr",
          "when": "true"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tunr.share",
        "key": "ctrl+shift+p ctrl+shift+t",
        "mac": "cmd+shift+p cmd+shift+t"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node build.js",
    "package": "npx vsce package",
    "publish": "npx vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0"
  }
}
